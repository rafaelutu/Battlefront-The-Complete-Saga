Group("player1energybar")
{
	PropagateAlpha(1);
	Viewport(1);
	Position();
	EventEnable("player1.energyFraction");
	EventDisable("player1.energyDisable");
	BarBitmap("player1energy_fill")
	{
		FlashyScale(1);
		EventValue("player1.energyFraction");
		Bitmap("hud_lego_stamina");
		BitmapRect();
		Position();
		Scale(0.950000, 0.950000, 0.950000);
		Alpha(0.800000);
		ZOrder(0);
		EventEnable("player1.energyFraction");
		EventColor("player1.energyColor");
		EventDisable("player1.energyDisable");
		EventPulseRate("player1.energyRegenPulseRate");
	}

	Bitmap("player1energy_empty")
	{
		Bitmap("hud_lego_stamina_empty");
		Position();
		BitmapRect();
		Color(255, 255, 255);
		Scale(0.950000, 0.950000, 0.950000);
		Alpha(0.500000);
		ZOrder(1);
		EventEnable("initialize");
	}

}

