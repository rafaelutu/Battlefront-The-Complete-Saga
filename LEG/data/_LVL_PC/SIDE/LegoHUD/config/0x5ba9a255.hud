FileInfo("legocrosshair")
{
	Viewports(1);
}

Viewport("Transforms")
{
	EventNameFilter("player%");
	TransformNumberColor("player1targetteamcolor")
	{
		NumberColor(0, 255, 255, 255);
		NumberColor(1, 0, 0, 255);
		NumberColor(2, 255, 0, 0);
		EventInput("player1.weapon1.target.team");
		EventOutput("player1.teamColor");
	}

	TransformNumberColor("player1energyfractioncolor")
	{
		NumberColor(0.100000, 31, 29, 31);
		NumberColor(0.200000, 55, 50, 25);
		NumberColor(0.300000, 80, 69, 23);
		NumberColor(0.400000, 107, 91, 19);
		NumberColor(0.500000, 136, 115, 18);
		NumberColor(0.600000, 163, 137, 15);
		NumberColor(0.700000, 185, 155, 7);
		NumberColor(0.800000, 210, 175, 7);
		NumberColor(0.900000, 230, 190, 2);
		NumberColor(1, 255, 220, 0);
		EventInput("player1.energyFraction");
		EventOutput("player1.energyColor");
	}

}

Group("player1healthbar")
{
	PropagateAlpha(1);
	Viewport(1);
	Position();
	FadeInTime(0.500000);
	FadeOutTime(0.500000);
	EventEnable("player1.health");
	EventDisable("player1.healthDisable");
	Bitmap("player1charback")
	{
		Bitmap("hud_lego_charback");
		Position();
		BitmapRect();
		Color(255, 255, 255);
		Alpha(1);
		ZOrder(2);
		EventEnable("player1.healthFraction");
		EventDisable("player1.healthDisable");
	}

	Bitmap("player1charicon")
	{
		Bitmap("hud_lego_charicon");
		Position();
		BitmapRect();
		Color(255, 255, 255);
		Alpha(0.800000);
		ZOrder(1);
		EventEnable("player1.healthFraction");
		EventDisable("player1.healthDisable");
	}

	Bitmap("player1charteam")
	{
		Bitmap("hud_lego_charback_ring");
		Position();
		BitmapRect();
		Color(33, 193, 0, 0);
		Alpha(1);
		ZOrder(1);
		EventEnable("player1.healthFraction");
		EventDisable("player1.healthDisable");
	}

	BarSegmented("player1health_fill")
	{
		Circular(0);
		NumSegments(8);
		Value(1);
		EventValue("player1.healthFraction");
		Rect();
		Position();
		PropagateAlpha(1);
		Alpha(1);
		Color(255, 0, 0);
		ZOrder(0);
		EventEnable("player1.healthFraction");
		EventDisable("player1.healthDisable");
		Segment("Segment")
		{
			Bitmap("hud_lego_healthbar");
			BitmapRect();
			FadeInTime(0.050000);
			FadeOutTime(0.100000);
		}

	}

	BarSegmented("player1health_empty")
	{
		Circular(0);
		NumSegments(8);
		Value(1);
		Rect();
		Position();
		PropagateAlpha(1);
		Alpha(0.400000);
		Color(255, 0, 0);
		ZOrder(0);
		EventEnable("player1.healthFraction");
		EventDisable("player1.healthDisable");
		Segment("Segment")
		{
			Bitmap("hud_lego_healthbar");
			BitmapRect();
			FadeInTime(0.050000);
			FadeOutTime(0.100000);
		}

	}

	BarSegmented("player1shield_fill")
	{
		Circular(0);
		NumSegments(4);
		Value(1);
		EventValue("player1.jetFuelFraction");
		Rect();
		Position();
		PropagateAlpha(1);
		Alpha(1);
		Color(255, 255, 255);
		ZOrder(0);
		EventEnable("player1.jetFuelFraction");
		EventDisable("player1.jetDisable");
		Segment("Segment")
		{
			Bitmap("hud_lego_jetbar");
			BitmapRect();
			FadeInTime(0.050000);
			FadeOutTime(0.100000);
		}

	}

	BarSegmented("player1shield_empty")
	{
		Circular(0);
		NumSegments(4);
		Value(1);
		Rect();
		Position();
		PropagateAlpha(1);
		Alpha(0.300000);
		Color(255, 255, 255);
		ZOrder(1);
		EventEnable("player1.jetFuelFraction");
		EventDisable("player1.jetDisable");
		Segment("Segment")
		{
			Bitmap("hud_lego_jetbar");
			BitmapRect();
			FadeInTime(0.050000);
			FadeOutTime(0.100000);
		}

	}

