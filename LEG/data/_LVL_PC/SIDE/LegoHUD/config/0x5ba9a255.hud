Group("player1vehicleseatinggroup")
{
	PropagateAlpha(1);
	Position();
	FadeInTime(0.250000);
	FadeHoldTime(4);
	FadeOutTime(0.250000);
	EventEnable("player1.vehicle.seatingMesh");
	EventDisable("player1.vehicle.healthDisable");
	VehicleSeating("player1vehicleseating")
	{
		EventPlayerIndex("player1.index");
		PropagateAlpha(1);
		EventEnable("initialize");
		Backdrop("Backdrop")
		{
		}

		Empty("Empty")
		{
			Mesh("hud_lego_stud_silver");
			Position();
			Rotation(360, 360, 345);
			Scale(0.300000, 0.300000, 0.300000);
			Alpha(0.700000);
		}

		EmptyText("EmptyText")
		{
			TextBreak("Word");
			TextFont("gamefont_lego_medium");
			TextStyle("Shadow");
			Alpha(0.500000);
		}

		self("Self")
		{
			Mesh("hud_lego_stud_gold");
			Position();
			Rotation(360, 360, 345);
			Scale(0.300000, 0.300000, 0.300000);
			Alpha(1);
		}

		SelfText("SelfText")
		{
			TextBreak("Word");
			TextFont("gamefont_lego_medium");
			TextStyle("Shadow");
		}

		Player("Player")
		{
			Mesh("hud_lego_stud_gold");
			Position();
			Rotation(360, 360, 345);
			Scale(0.300000, 0.300000, 0.300000);
			Alpha(1);
		}

		PlayerText("PlayerText")
		{
			TextBreak("Word");
			TextFont("gamefont_lego_medium");
			TextStyle("Shadow");
			Alpha(0.500000);
		}

		AI("AI")
		{
			Mesh("hud_lego_stud_purple");
			Position();
			Rotation(360, 360, 345);
			Scale(0.300000, 0.300000, 0.300000);
			Alpha(1);
		}

		AIText("AIText")
		{
			TextBreak("Word");
			TextFont("gamefont_lego_medium");
			TextStyle("Shadow");
			Alpha(0.500000);
		}

	}

}

