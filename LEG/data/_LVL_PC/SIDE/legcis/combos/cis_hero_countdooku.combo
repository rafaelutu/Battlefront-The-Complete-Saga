Animation("jumpattack_land");
State("JUMPATTACK_FALL")
{
	Posture("Jump");
	Animation("jumpattack_fall")
	{
		Loop("FinalFrame");
		AimType("None");
		BlendInTime(0.150000);
		BlendOutTime(0.150000);
	}

	Sound("com_weap_throw");
	Duration(0);
	EnergyRestoreRate(0);
	Gravity(4);
	GravityVelocityTarget(-15);
	AnimatedMove()
	{
		VelocityFromThrust(90);
		VelocityFromStrafe(0);
	}

	InputLock("All", "!Thrust");
	AlignedToThrust();
	Transition("JUMPATTACK_LAND")
	{
		If()
		{
			Break();
			Posture("Stand");
		}

	}

	Transition("IDLE")
	{
		If()
		{
			Break();
			Posture("Any", "!Stand", "!Jump", "!Jet");
		}

	}

}

