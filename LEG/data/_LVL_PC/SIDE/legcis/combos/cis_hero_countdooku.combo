State("BACK_ATTACK")
{
	Posture("Stand");
	Animation("stand_attack_backwards")
	{
		BlendInTime(0.150000);
		BlendOutTime(0.150000);
	}

	Sound("saber_double", "Frames");
	Duration("Frames", 0);
	InputLock("All", "!Thrust");
	AlignedToThrust();
	Attack()
	{
		DamageTime();
		DamageLength(1.500000);
		DamageWidth(0.750000);
		Damage(300);
		Push(6);
	}

	Attack()
	{
		DamageTime();
		DamageLength(1.500000);
		DamageWidth(0.750000);
		Damage(300);
		Push(6);
	}

	Transition("IDLE");
}

