}

State("IDLE")
{
	Duration(0);
	EnergyRestoreRate();
	InputLock();
	Transition("DEFLECT")
	{
		If()
		{
			Break();
			Posture("Stand", "Crouch");
			Energy(">=");
			Button("FireSecondary", "Press");
		}

	}

	Transition("BACK_ATTACK")
	{
		If()
		{
			Break();
			Posture("Stand", "Crouch");
			Button("Fire", "Press");
			Thrust(">");
			ThrustAngle(135, 225);
		}

	}

	Transition("ATTACK1")
	{
		If()
		{
			Break();
			Posture("Stand", "Crouch");
			Button("Fire", "Press");
		}

	}

	Transition("DASHATTACK")
	{
		If()
		{
			Break();
			Posture("Sprint");
			Button("Fire", "Press");
		}

	}

	Transition("JUMPATTACK_FALL")
	{
		If()
		{
			Break();
			Posture("Jump", "Jet");
			Button("Fire", "Press");
		}

	}

}

State("DEFLECT")
{
	Posture("Stand");
	Sound("imp_weap_lightsabre_block");
	Animation("stand_block_idle")
	{
		Loop();
		AimType("None");
		BlendInTime(0.150000);
		BlendOutTime(0.150000);
		LowResPose("Frames", 0);
	}

	Duration(0);
	InputLock();
	EnergyRestoreRate(-10);
	Deflect()
	{
		DeflectAngle(-60, 60);
		EnergyCost(0);
		DeflectAnimation("stand_block_front1", "Forward")
		{
			BlendInTime(0);
			BlendOutTime(0.050000);
			LowResPose("Frames", 0);
		}

		DeflectAnimation("stand_block_front2", "Forward")
		{
			BlendInTime(0);
			BlendOutTime(0.050000);
			LowResPose("Frames", 0);
		}

		DeflectAnimation("stand_block_left1", "Left")
		{
			BlendInTime(0);
			BlendOutTime(0.050000);
			LowResPose("Frames", 0);
		}

		DeflectAnimation("stand_block_left2", "Left")
		{
			BlendInTime(0);
			BlendOutTime(0.050000);
			LowResPose("Frames", 0);
		}

		DeflectAnimation("stand_block_right1", "Right")
		{
			BlendInTime(0);
			BlendOutTime(0.050000);
			LowResPose("Frames", 0);
		}

		DeflectAnimation("stand_block_right2", "Right")
		{
			BlendInTime(0);
			BlendOutTime(0.050000);
			LowResPose("Frames", 0);
		}

	}

	Transition("ATTACK1")
	{
		If()
		{
			Break();
			Button("Fire", "Press");
		}

	}

	Transition("DEFLECT_ROLL")
	{
		EnergyCost(25);
		If()
		{
			Break();
			Button("Crouch", "Press");
			Thrust(">");
			ThrustAngle(-120, 120);
		}

	}

	Transition("DEFLECT_CROUCH")
	{
		If()
		{
			Break();
			Button("Crouch", "Press");
		}

	}

	Transition("DEFLECT_JUMP")
	{
		If()
		{
			Break();
			Button("Jump", "Press");
		}

	}

	Transition("DEFLECT_SPRINT")
	{
		If()
		{
			Break();
			Button("Sprint", "Down");
		}

	}

	Transition("IDLE")
	{
		If()
		{
			Break();
			Energy("<=");
		}

		Or()
		{
			Break("Frames", 0);
			Button("FireSecondary", "Press");
		}

		Or()
		{
			Break();
			Button("Reload", "Press");
		}

	}

}

